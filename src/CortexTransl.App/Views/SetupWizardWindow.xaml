<Window x:Class="CortexTransl.App.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cortex Transl - Setup Wizard"
        Width="600"
        Height="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Welcome to Cortex Transl"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,20" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="How will you use the app?" Style="{StaticResource InputLabel}" />
            <ComboBox x:Name="UsageTypeComboBox"
                      Margin="0,0,0,15"
                      SelectedIndex="0">
                <ComboBoxItem Content="Game Dialogue" Tag="Game Dialogue" />
                <ComboBoxItem Content="Visual Novel" Tag="Visual Novel" />
                <ComboBoxItem Content="Fullscreen Game" Tag="Fullscreen Game" />
                <ComboBoxItem Content="Menu / UI Translation" Tag="Menu / UI Translation" />
            </ComboBox>

            <TextBlock Text="Translation Provider" Style="{StaticResource InputLabel}" />
            <ComboBox x:Name="ProviderComboBox"
                      Margin="0,0,0,5"
                      SelectedIndex="0">
                <ComboBoxItem Content="Placeholder (For Testing)" Tag="placeholder" />
                <ComboBoxItem Content="DeepL" Tag="deepl" />
            </ComboBox>
            <TextBlock Text="Note: DeepL requires an API Key to be configured later."
                       Style="{StaticResource HintText}"
                       Margin="0,0,0,15" />

            <TextBlock Text="Use Game Dialogue or Visual Novel for subtitles. Use Menu / UI Translation for settings windows, inventory panels, quests, and other dense UI text."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,10,0,15" />

        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Finish &amp; Start Translating"
                    Style="{StaticResource PrimaryButton}"
                    Click="FinishButton_Click"
                    MinWidth="150" />
        </StackPanel>
    </Grid>
</Window>
