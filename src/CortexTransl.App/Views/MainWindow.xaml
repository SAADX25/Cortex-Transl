<Window x:Class="CortexTransl.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cortex Transl"
        Width="1080"
        Height="760"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="16,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Cortex Transl" FontSize="22" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock Text="{Binding SelectedRegionDisplay}" Foreground="#475569" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Select Region" Command="{Binding SelectRegionCommand}" />
                    <Button Content="Capture &amp; Translate" Command="{Binding CaptureAndTranslateCommand}" Background="{StaticResource AccentBrush}" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="Settings" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,0,8,8" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding SourceLanguageOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SourceLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Target" VerticalAlignment="Center" Margin="0,0,8,8" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding TargetLanguageOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TargetLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="OCR" VerticalAlignment="Center" Margin="0,0,8,8" />
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding OcrEngineOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OcrEngine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Provider" VerticalAlignment="Center" Margin="0,0,8,8" />
                            <ComboBox Grid.Row="3" Grid.Column="1"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding TranslationProviderOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TranslationProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Font size" VerticalAlignment="Center" Margin="0,0,8,8" />
                            <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Right" Text="{Binding OverlayFontSize, StringFormat={}{0:0}}" Width="34" TextAlignment="Right" VerticalAlignment="Center" />
                                <Slider Minimum="18" Maximum="56" TickFrequency="2" IsSnapToTickEnabled="True" Value="{Binding OverlayFontSize, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <DockPanel Grid.Row="5" Grid.Column="1">
                                <TextBlock DockPanel.Dock="Right" Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}" Width="44" TextAlignment="Right" VerticalAlignment="Center" />
                                <Slider Minimum="0.35" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding OverlayOpacity, Mode=TwoWay}" />
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Profile" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Name" Margin="0,0,0,4" />
                            <TextBox AutomationProperties.AutomationId="ProfileName"
                                     AutomationProperties.Name="Profile Name"
                                     Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" />
                            <TextBlock Text="Saved" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save" Command="{Binding SaveProfileCommand}" />
                                <Button Content="Load" Command="{Binding LoadSelectedProfileCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Debug" Padding="12" Margin="0,0,0,12">
                        <ItemsControl ItemsSource="{Binding DebugMetrics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="#475569" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <GroupBox Header="Timing Log" Padding="12">
                        <ListBox ItemsSource="{Binding LastTimings}" MinHeight="100" BorderThickness="0" Background="Transparent" />
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Original Text" Padding="12">
                    <TextBox AutomationProperties.AutomationId="OriginalTextOutput"
                             AutomationProperties.Name="Original Text Output"
                             Text="{Binding OriginalText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="18"
                             Background="White" />
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Arabic Translation" Padding="12">
                    <TextBox AutomationProperties.AutomationId="TranslatedTextOutput"
                             AutomationProperties.Name="Translated Text Output"
                             Text="{Binding TranslatedText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="22"
                             FlowDirection="RightToLeft"
                             TextAlignment="Right"
                             Background="White" />
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="16,8">
            <DockPanel>
                <TextBlock AutomationProperties.AutomationId="StatusMessage"
                           AutomationProperties.Name="{Binding StatusMessage}"
                           Text="{Binding StatusMessage}"
                           Foreground="#334155"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="F8" Foreground="#64748B" VerticalAlignment="Center" FontWeight="SemiBold" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
