<Window x:Class="CortexTransl.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cortex Transl"
        Width="1180"
        Height="720"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top header -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel LastChildFill="False">

                <!-- App identity & Mode -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Cortex Transl"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,20,0" />

                    <Button Content="Setup Wizard"
                            Style="{StaticResource SecondaryButton}"
                            Click="RunSetupWizard_Click"
                            Margin="15,0,0,0"
                            Padding="10,2" />

                    <Button Content="Simple"
                            Style="{StaticResource SecondaryButton}"
                            Click="SimpleMode_Click"
                            Padding="10,2" />

                    <Button Content="Advanced"
                            Style="{StaticResource SecondaryButton}"
                            Click="AdvancedMode_Click"
                            Padding="10,2" />
                </StackPanel>

                <!-- Region + quick action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Content="Select Region"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectRegionCommand}"
                            MinWidth="130"
                            ToolTip="F9 Select Region" />

                    <Button Content="{Binding CaptureButtonLabel}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CaptureAndTranslateCommand}"
                            MinWidth="130"
                            ToolTip="F10 Capture Once / Translate Region" />

                    <!-- Start / Stop Auto Translate Header Button -->
                    <Button Command="{Binding ToggleAutoTranslateCommand}"
                            Content="{Binding AutoTranslateButtonLabel}"
                            MinWidth="160"
                            ToolTip="F8 Toggle Auto Translate">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutoTranslateEnabled}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSubtitleMode}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main body -->
        <Grid Grid.Row="1" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <!-- Left sidebar -->
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <!-- Right main area -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Translation setup -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="TRANSLATION SETUP" Style="{StaticResource SectionTitle}" />

                            <TextBlock Text="Translation Mode" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding TranslationModeOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TranslationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Theme" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <StackPanel Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Translation Quality" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding TranslationQualityOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding TranslationQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <TextBlock Text="Source Language" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding SourceLanguageOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SourceLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <TextBlock Text="Target Language" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding TargetLanguageOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding TargetLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="OCR Engine" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding OcrEngineOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding OcrEngine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <TextBlock Text="OCR Preset" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding OcrPresetOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding OcrPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />
                            </StackPanel>

                            <TextBlock Text="Provider" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding TranslationProviderOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TranslationProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,4" />
                            
                            <TextBlock Text="{Binding ProviderHint}"
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="{Binding ModeInstructionText}"
                                       Style="{StaticResource HintText}"
                                       Margin="0,8,0,10" />

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Select Region"
                                        Command="{Binding SelectRegionCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="120"
                                        ToolTip="F9 Select Region" />
                                <Button Content="{Binding CaptureButtonLabel}"
                                        Command="{Binding CaptureAndTranslateCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="150"
                                        ToolTip="F10 Capture Once / Translate Region" />
                                <Button Command="{Binding ToggleAutoTranslateCommand}"
                                        Content="{Binding AutoTranslateButtonLabel}"
                                        MinWidth="150"
                                        ToolTip="F8 Toggle Auto Translate">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAutoTranslateEnabled}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSubtitleMode}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Lens Mode -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsLensMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="LENS MODE" Style="{StaticResource SectionTitle}" />

                            <CheckBox IsChecked="{Binding ShowInlineTranslationsOnScreen, Mode=TwoWay}"
                                      Margin="0,0,0,10">
                                <TextBlock Text="Show inline translations on screen"
                                           TextWrapping="Wrap" />
                            </CheckBox>

                            <TextBlock Text="Overlay style" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding LensOverlayStyleOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding LensOverlayStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8"
                                      ToolTip="Choose how Lens translations attach to each detected OCR box." />

                            <CheckBox IsChecked="{Binding LensReplaceOriginalText, Mode=TwoWay}"
                                      Margin="0,0,0,8"
                                      ToolTip="When enabled, Compact Lens and Replace styles draw Arabic inside the source text box. When disabled, translations stay beside the original.">
                                <TextBlock Text="Replace original text visually / Show beside original"
                                           TextWrapping="Wrap" />
                            </CheckBox>

                            <CheckBox IsChecked="{Binding TranslateAppNames, Mode=TwoWay}"
                                      Margin="0,0,0,8"
                                      ToolTip="When off, Lens Mode preserves app, brand, and file names like Steam, Discord, and Chrome.">
                                <TextBlock Text="Translate app names"
                                           TextWrapping="Wrap" />
                            </CheckBox>

                            <CheckBox IsChecked="{Binding HideMainWindowDuringLensCapture, Mode=TwoWay}"
                                      Margin="0,0,0,10"
                                      ToolTip="Temporarily hides Cortex Transl during Lens capture so it does not OCR its own window.">
                                <TextBlock Text="Hide main app window during Lens capture"
                                           TextWrapping="Wrap" />
                            </CheckBox>

                            <Border Background="{DynamicResource DebugMetricBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Height="112"
                                    Margin="0,0,0,12"
                                    ClipToBounds="True">
                                <Canvas>
                                    <TextBlock Canvas.Left="12"
                                               Canvas.Top="10"
                                               Text="Overlay Style Preview"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />

                                     <Border Canvas.Left="64"
                                             Canvas.Top="44"
                                             Width="104"
                                            Height="24"
                                            Background="#221E293B"
                                            BorderBrush="#6694A3B8"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Opacity="{Binding LensPreviewSourceOpacity}">
                                        <TextBlock Text="Control Panel"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>

                                    <Border Canvas.Left="{Binding LensPreviewCardLeft}"
                                            Canvas.Top="{Binding LensPreviewCardTop}"
                                            Width="{Binding LensPreviewCardWidth}"
                                            Height="{Binding LensPreviewCardHeight}"
                                            Background="#D9020617"
                                            BorderBrush="#99FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Opacity="{Binding LensPreviewCardOpacity}"
                                            Padding="4,1">
                                        <TextBlock Text="&#x0644;&#x0648;&#x062D;&#x0629; &#x0627;&#x0644;&#x062A;&#x062D;&#x0643;&#x0645;"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   FlowDirection="RightToLeft"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Canvas>
                            </Border>

                            <TextBlock Text="OCR granularity" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding OcrGranularityOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OcrGranularity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,12" />

                            <Button Content="Clear Overlay"
                                    Command="{Binding ClearTranslationCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="120"
                                    HorizontalAlignment="Left"
                                    ToolTip="F7 Clear Overlay" />
                        </StackPanel>
                    </Border>

                    <!-- DeepL API -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="DEEPL API" Style="{StaticResource SectionTitle}" />

                            <TextBlock Text="API Key" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,4">
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="View"
                                        Width="52"
                                        MinHeight="30"
                                        Margin="4,0,0,0"
                                        Click="ToggleApiKeyVisibility_Click"
                                        ToolTip="Show / Hide API Key" />
                                <Grid>
                                    <PasswordBox x:Name="ApiKeyPasswordBox"
                                                 PasswordChanged="ApiKeyPasswordBox_PasswordChanged" />
                                    <TextBox x:Name="ApiKeyTextBox"
                                             Visibility="Collapsed"
                                             Text="{Binding DeepLApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </DockPanel>
                            <TextBlock Text="{Binding ApiKeyStatusText}"
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,10" />

                            <CheckBox Content="DeepL Free API"
                                      IsChecked="{Binding UseDeepLFreeApi, Mode=TwoWay}" />
                            <TextBlock Text="Keep your API key private."
                                       Style="{StaticResource HintText}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Auto Translate -->
                    <Border Style="{StaticResource CardBorder}" Visibility="{Binding ShowSubtitleAdvancedControls, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="AUTO TRANSLATE" Style="{StaticResource SectionTitle}" />

                            <!-- Status text -->
                            <TextBlock Text="{Binding AutoTranslateStatusText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoTranslateEnabled}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="Interval" Style="{StaticResource InputLabel}" />
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AutoTranslateIntervalMs, StringFormat={}{0:0} ms}"
                                           Width="52"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="300"
                                        Maximum="3000"
                                        TickFrequency="100"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding AutoTranslateIntervalMs, Mode=TwoWay}" />
                            </DockPanel>

                        </StackPanel>
                    </Border>

                    <!-- Overlay -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding ShowSubtitleAdvancedControls, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="OVERLAY" Style="{StaticResource SectionTitle}" />
                            
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Show Overlay"
                                        Command="{Binding ShowOverlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="120" />
                                <Button Content="Hide Overlay"
                                        Command="{Binding HideOverlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="100"
                                        ToolTip="Hide the translation overlay" />
                                <Button Content="Clear Translation"
                                        Command="{Binding ClearTranslationCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="130"
                                        ToolTip="Clear current text and reset translation state" />
                            </WrapPanel>

                            <!-- Simple settings -->
                            <TextBlock Text="Position Preset" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding OverlayPositionOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OverlayPositionPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Font Size" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayFontSize, StringFormat={}{0:0} pt}"
                                           Width="48"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="18"
                                        Maximum="56"
                                        TickFrequency="2"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayFontSize, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Text="Overlay Opacity" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}"
                                           Width="48"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="0.35"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayOpacity, Mode=TwoWay}" />
                            </DockPanel>

                            <!-- Advanced settings -->
                            <StackPanel Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Overlay Position Mode" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding OverlayPositionModeOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding OverlayPositionMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,6" />

                                <TextBlock Text="{Binding OverlayPositionStatusText}"
                                           Style="{StaticResource HintText}"
                                           Margin="0,0,0,10" />

                                <Button Content="{Binding OverlayPositionLockButtonLabel}"
                                        Command="{Binding ToggleOverlayPositionLockCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="180"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,10"
                                        ToolTip="Unlock the overlay so it can be dragged to a custom position" />

                                <CheckBox Content="Recording Compatibility Mode"
                                          IsChecked="{Binding RecordingCompatibilityMode, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Render Mode" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding OverlayRenderModeOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding OverlayRenderMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <CheckBox Content="Click-through overlay"
                                          IsChecked="{Binding OverlayClickThrough, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Max Width" Style="{StaticResource InputLabel}" />
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding OverlayMaxWidth, StringFormat={}{0:0}px}"
                                               Width="58"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <Slider Minimum="360"
                                            Maximum="1400"
                                            TickFrequency="40"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding OverlayMaxWidth, Mode=TwoWay}" />
                                </DockPanel>

                                <TextBlock Text="Background Opacity" Style="{StaticResource InputLabel}" />
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding OverlayBackgroundOpacity, StringFormat={}{0:P0}}"
                                               Width="48"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <Slider Minimum="0.35"
                                            Maximum="1"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding OverlayBackgroundOpacity, Mode=TwoWay}" />
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Profile -->
                    <Expander Header="PROFILE" Margin="0,0,0,10"
                              Foreground="{DynamicResource SectionHeaderBrush}"
                              FontWeight="SemiBold" FontSize="12"
                              Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Profile Name" Style="{StaticResource InputLabel}" />
                                <TextBox AutomationProperties.AutomationId="ProfileName"
                                         AutomationProperties.Name="Profile Name"
                                         Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8" />

                                <TextBlock Text="Saved Profiles" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                          Margin="0,0,0,10" />

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding SaveProfileCommand}"
                                            MinWidth="80" />
                                    <Button Content="Load"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding LoadSelectedProfileCommand}"
                                            MinWidth="80" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Expander>
                    
                    <!-- Glossary Placeholder -->
                    <Expander Header="GLOSSARY" Margin="0,0,0,10"
                              Foreground="{DynamicResource SectionHeaderBrush}"
                              FontWeight="SemiBold" FontSize="12">
                        <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Glossary and Dictionary features are coming soon. Context-aware story translation will be available in future updates."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <Button Content="Manage Glossary (Coming Soon)"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="False" />
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- Right main area -->
            <ScrollViewer Grid.Column="2" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <StackPanel>
                    <!-- Session Status / Last Activity Card -->
                    <Border Style="{StaticResource CardBorder}" Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="SESSION STATUS" Style="{StaticResource SectionTitle}" />
                            <ItemsControl ItemsSource="{Binding DebugMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource DebugMetricBackgroundBrush}" 
                                                CornerRadius="4" 
                                                Padding="8,4" 
                                                Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{DynamicResource LabelBrush}" 
                                                           FontSize="11" 
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Value}" 
                                                           Foreground="{DynamicResource PrimaryTextBrush}" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Live Translation Preview Card -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsSubtitleMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <Border Style="{StaticResource StatusPill}" DockPanel.Dock="Right">
                                    <TextBlock Text="{Binding SelectedRegionDisplay}"
                                               FontSize="11"
                                               Foreground="{DynamicResource StatusPillTextBrush}"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="LIVE TRANSLATION PREVIEW" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0" />
                            </DockPanel>
                            
                            <Border Style="{StaticResource TextPanel}">
                                <Grid MinHeight="80" MaxHeight="250">
                                    <TextBlock Text="Translation will appear here."
                                               FontSize="16"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TranslatedText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TranslatedText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox AutomationProperties.AutomationId="TranslatedTextOutput"
                                                 AutomationProperties.Name="Translated Text Output"
                                                 Text="{Binding TranslatedText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 FontSize="24"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FlowDirection="RightToLeft"
                                                 TextAlignment="Right"
                                                 VerticalContentAlignment="Top" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Screen Translation Result -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsRegionTranslationMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <Button DockPanel.Dock="Right"
                                        Content="Copy All"
                                        Command="{Binding CopyMenuTranslationsCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="90" />
                                <StackPanel>
                                    <TextBlock Text="{Binding ScreenTranslationTitle}"
                                               Style="{StaticResource SectionTitle}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding MenuResultHint}"
                                               Style="{StaticResource HintText}" />
                                </StackPanel>
                            </DockPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Original"
                                           Style="{StaticResource InputLabel}"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2"
                                           Text="Arabic"
                                           Style="{StaticResource InputLabel}"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right" />
                            </Grid>

                            <Border Style="{StaticResource TextPanel}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              MaxHeight="420">
                                    <ItemsControl ItemsSource="{Binding MenuTextBlocks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Text}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                                            <TextBlock Text="{Binding BoundsDisplay}"
                                                                       Style="{StaticResource SmallMutedText}"
                                                                       Margin="0,6,0,0" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="2"
                                                            Background="{DynamicResource CardBackgroundBrush}"
                                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10">
                                                        <TextBlock Text="{Binding TranslatedText}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="15"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   FlowDirection="RightToLeft"
                                                                   TextAlignment="Right" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Border Style="{StaticResource TextPanel}">
                                <TextBox AutomationProperties.AutomationId="MenuTranslatedTextFallback"
                                         AutomationProperties.Name="Menu Translated Text Fallback"
                                         Text="{Binding TranslatedText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="70"
                                         MaxHeight="180"
                                         FontSize="15"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FlowDirection="RightToLeft"
                                         TextAlignment="Right"
                                         VerticalContentAlignment="Top" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Detected Original Text (Collapsible) -->
                    <Expander Header="DETECTED ORIGINAL TEXT" 
                              IsExpanded="True"
                              Foreground="{DynamicResource SectionHeaderBrush}"
                              FontWeight="SemiBold" FontSize="12"
                              Margin="0,0,0,16"
                              Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                        <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource TextPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150" MinHeight="60">
                                        <TextBox AutomationProperties.AutomationId="OriginalTextOutput"
                                                 AutomationProperties.Name="Original Text Output"
                                                 Text="{Binding OriginalText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 FontSize="13"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                                 VerticalContentAlignment="Top" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,0">
                    <TextBlock Text="F8" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text=" Toggle Auto    " Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <TextBlock Text="F9" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text=" Select Region    " Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <TextBlock Text="F10" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text=" " Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <TextBlock Text="{Binding F10ActionText, Mode=OneWay}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                </StackPanel>
                <TextBlock AutomationProperties.AutomationId="StatusMessage"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
