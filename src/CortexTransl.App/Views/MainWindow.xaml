<Window x:Class="CortexTransl.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cortex Transl"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top header bar -->
            <RowDefinition Height="Auto" />
            <!-- Main content -->
            <RowDefinition Height="*" />
            <!-- Status footer -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top header -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel LastChildFill="False">

                <!-- App identity -->
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Cortex Transl"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>

                <!-- Region + quick action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Region display pill -->
                    <Border Style="{StaticResource StatusPill}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedRegionDisplay}"
                                       FontSize="12"
                                       Foreground="{DynamicResource StatusPillTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Content="Select Region"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectRegionCommand}"
                            MinWidth="130"
                            ToolTip="F9 Select Region" />

                    <Button Content="Capture Once"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CaptureAndTranslateCommand}"
                            MinWidth="130"
                            ToolTip="F10 Capture Once" />

                    <!-- Start / Stop Auto Translate Header Button -->
                    <Button Command="{Binding ToggleAutoTranslateCommand}"
                            Content="{Binding AutoTranslateButtonLabel}"
                            MinWidth="160"
                            ToolTip="F8 Toggle Auto Translate">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutoTranslateEnabled}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main body -->
        <Grid Grid.Row="1" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <!-- Left sidebar -->
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="16" />
                <!-- Right main area -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Translation setup -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="TRANSLATION SETUP" Style="{StaticResource SectionTitle}" />

                            <TextBlock Text="Theme" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Source Language" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding SourceLanguageOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SourceLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Target Language" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding TargetLanguageOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TargetLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="OCR Engine" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding OcrEngineOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OcrEngine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Provider" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding TranslationProviderOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding TranslationProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,4" />
                            
                            <TextBlock Text="{Binding ProviderHint}"
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,4" />
                        </StackPanel>
                    </Border>

                    <!-- DeepL API -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="DEEPL API" Style="{StaticResource SectionTitle}" />

                            <TextBlock Text="API Key" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,4">
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="View"
                                        Width="52"
                                        MinHeight="30"
                                        Margin="4,0,0,0"
                                        Click="ToggleApiKeyVisibility_Click"
                                        ToolTip="Show / Hide API Key" />
                                <Grid>
                                    <PasswordBox x:Name="ApiKeyPasswordBox"
                                                 PasswordChanged="ApiKeyPasswordBox_PasswordChanged" />
                                    <TextBox x:Name="ApiKeyTextBox"
                                             Visibility="Collapsed"
                                             Text="{Binding DeepLApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </DockPanel>
                            <TextBlock Text="{Binding ApiKeyStatusText}"
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,0,10" />

                            <CheckBox Content="DeepL Free API"
                                      IsChecked="{Binding UseDeepLFreeApi, Mode=TwoWay}" />
                            <TextBlock Text="Keep your API key private."
                                       Style="{StaticResource HintText}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Auto Translate -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="AUTO TRANSLATE" Style="{StaticResource SectionTitle}" />

                            <!-- Status text -->
                            <TextBlock Text="{Binding AutoTranslateStatusText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoTranslateEnabled}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>


                            <TextBlock Text="Interval" Style="{StaticResource InputLabel}" />
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AutoTranslateIntervalMs, StringFormat={}{0:0} ms}"
                                           Width="52"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="300"
                                        Maximum="3000"
                                        TickFrequency="100"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding AutoTranslateIntervalMs, Mode=TwoWay}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Overlay -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="OVERLAY" Style="{StaticResource SectionTitle}" />
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Show Overlay"
                                        Command="{Binding ShowOverlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="120" />
                                <Button Content="Hide Overlay"
                                        Command="{Binding HideOverlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="100" />
                            </StackPanel>

                            <CheckBox Content="Recording Compatibility Mode"
                                      IsChecked="{Binding RecordingCompatibilityMode, Mode=TwoWay}"
                                      Margin="0,0,0,8" />

                            <TextBlock Text="Render Mode" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding OverlayRenderModeOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OverlayRenderMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <CheckBox Content="Click-through overlay"
                                      IsChecked="{Binding OverlayClickThrough, Mode=TwoWay}"
                                      Margin="0,0,0,8" />

                            <TextBlock Text="Position" Style="{StaticResource InputLabel}" />
                            <ComboBox ItemsSource="{Binding OverlayPositionOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding OverlayPositionPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Font Size" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayFontSize, StringFormat={}{0:0} pt}"
                                           Width="48"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="18"
                                        Maximum="56"
                                        TickFrequency="2"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayFontSize, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Text="Max Width" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayMaxWidth, StringFormat={}{0:0}px}"
                                           Width="58"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="360"
                                        Maximum="1400"
                                        TickFrequency="40"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayMaxWidth, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Text="Overlay Opacity" Style="{StaticResource InputLabel}" />
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}"
                                           Width="48"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="0.35"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayOpacity, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Text="Background Opacity" Style="{StaticResource InputLabel}" />
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OverlayBackgroundOpacity, StringFormat={}{0:P0}}"
                                           Width="48"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Slider Minimum="0.35"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding OverlayBackgroundOpacity, Mode=TwoWay}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Profile -->
                    <Expander Header="PROFILE" Margin="0,0,0,10"
                              Foreground="{DynamicResource SectionHeaderBrush}"
                              FontWeight="SemiBold" FontSize="12">
                        <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Profile Name" Style="{StaticResource InputLabel}" />
                                <TextBox AutomationProperties.AutomationId="ProfileName"
                                         AutomationProperties.Name="Profile Name"
                                         Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8" />

                                <TextBlock Text="Saved Profiles" Style="{StaticResource InputLabel}" />
                                <ComboBox ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                          Margin="0,0,0,10" />

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding SaveProfileCommand}"
                                            MinWidth="80" />
                                    <Button Content="Load"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding LoadSelectedProfileCommand}"
                                            MinWidth="80" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- Right main area -->
            <ScrollViewer Grid.Column="2" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <StackPanel>
                    <!-- Session Status / Last Activity Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="SESSION STATUS" Style="{StaticResource SectionTitle}" />
                            <ItemsControl ItemsSource="{Binding DebugMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource DebugMetricBackgroundBrush}" 
                                                CornerRadius="4" 
                                                Padding="8,4" 
                                                Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{DynamicResource LabelBrush}" 
                                                           FontSize="11" 
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Value}" 
                                                           Foreground="{DynamicResource PrimaryTextBrush}" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Live Translation Preview Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="LIVE TRANSLATION PREVIEW" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource SuccessBrush}" />
                            
                            <Border Style="{StaticResource TextPanel}">
                                <Grid MinHeight="80" MaxHeight="250">
                                    <TextBlock Text="Translation will appear here."
                                               FontSize="16"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TranslatedText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TranslatedText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox AutomationProperties.AutomationId="TranslatedTextOutput"
                                                 AutomationProperties.Name="Translated Text Output"
                                                 Text="{Binding TranslatedText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 FontSize="24"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FlowDirection="RightToLeft"
                                                 TextAlignment="Right"
                                                 VerticalContentAlignment="Top" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Detected Original Text (Collapsible) -->
                    <Expander Header="DETECTED ORIGINAL TEXT" 
                              IsExpanded="True"
                              Foreground="{DynamicResource SectionHeaderBrush}"
                              FontWeight="SemiBold" FontSize="12"
                              Margin="0,0,0,16">
                        <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource TextPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150" MinHeight="60">
                                        <TextBox AutomationProperties.AutomationId="OriginalTextOutput"
                                                 AutomationProperties.Name="Original Text Output"
                                                 Text="{Binding OriginalText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 FontSize="13"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                                 VerticalContentAlignment="Top" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0">
                    <Run Text="F8" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <Run Text=" Toggle Auto    " Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <Run Text="F9" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <Run Text=" Select Region    " Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                    <Run Text="F10" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                    <Run Text=" Capture Once" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                </TextBlock>
                <TextBlock AutomationProperties.AutomationId="StatusMessage"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>


