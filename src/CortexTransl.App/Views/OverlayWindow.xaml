<Window x:Class="CortexTransl.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False">
    <Border x:Name="OverlayChrome"
            Background="#DD020617"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="18,12">
        <TextBlock x:Name="TranslationText"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FlowDirection="RightToLeft"
                   Foreground="White"
                   FontWeight="SemiBold"
                   MaxWidth="920" />
    </Border>
</Window>
